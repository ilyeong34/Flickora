<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/black"
    android:gravity="center"
    android:orientation="vertical"
    android:paddingHorizontal="@dimen/flickora_padding_large"
    android:paddingVertical="@dimen/flickora_padding_large">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/load_error_message"
        android:textColor="@color/white"
        tools:text="@string/load_error_message" />

    <Button
        android:id="@+id/btn_retry"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/flickora_padding_medium"
        android:backgroundTint="@color/gray"
        android:text="@string/retry"
        android:textColor="@color/white" />

</LinearLayout>

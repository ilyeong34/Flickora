<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <View
        android:id="@+id/iv_backdrop"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:background="@color/dark_gray"
        app:layout_constraintDimensionRatio="1:0.5"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <View
        android:id="@+id/poster_default"
        android:layout_width="100dp"
        android:layout_height="140dp"
        android:layout_marginStart="@dimen/flickora_padding_large"
        android:background="@color/dark_gray"
        app:layout_constraintBottom_toBottomOf="@id/iv_backdrop"
        app:layout_constraintStart_toStartOf="parent" />

    <View
        android:id="@+id/tv_tv_title"
        android:layout_width="0dp"
        android:layout_height="20dp"
        android:layout_marginStart="@dimen/flickora_padding_large"
        android:background="@color/dark_gray"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@id/poster_default"
        app:layout_constraintTop_toTopOf="@id/poster_default" />

    <View
        android:id="@+id/rrv"
        android:layout_width="120dp"
        android:layout_height="18dp"
        android:layout_marginTop="@dimen/flickora_padding_large"
        android:background="@color/dark_gray"
        app:layout_constraintStart_toStartOf="@id/tv_tv_title"
        app:layout_constraintTop_toBottomOf="@id/tv_tv_title" />

</androidx.constraintlayout.widget.ConstraintLayout>

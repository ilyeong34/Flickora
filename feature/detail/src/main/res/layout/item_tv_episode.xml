<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="@dimen/flickora_padding_large"
    android:layout_marginVertical="@dimen/flickora_padding_medium"
    android:background="@color/black">

    <androidx.cardview.widget.CardView
        android:id="@+id/cv_episode_still"
        android:layout_width="120dp"
        android:layout_height="68dp"
        app:cardBackgroundColor="@color/dark_gray"
        app:cardCornerRadius="8dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/iv_episode_still"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:contentDescription="@string/des_tv_episode_still"
            android:scaleType="centerCrop"
            tools:src="@drawable/test_backdrop" />

        <TextView
            android:id="@+id/tv_episode_name1"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:textColor="@color/white"
            style="@style/TextAppearance.Material3.BodyMedium"
            tools:text="Episode title" />

    </androidx.cardview.widget.CardView>

    <TextView
        android:id="@+id/tv_episode_name2"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/flickora_padding_large"
        android:ellipsize="end"
        android:maxLines="1"
        android:textColor="@color/white"
        android:textSize="15sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@id/cv_episode_still"
        app:layout_constraintTop_toTopOf="@id/cv_episode_still"
        tools:text="Pilot" />

    <TextView
        android:id="@+id/tv_episode_runtime"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:textColor="@color/gray"
        android:textSize="12sp"
        app:layout_constraintEnd_toEndOf="@id/tv_episode_name2"
        app:layout_constraintStart_toStartOf="@id/tv_episode_name2"
        app:layout_constraintTop_toBottomOf="@id/tv_episode_name2"
        tools:text="Runtime   58m" />

    <TextView
        android:id="@+id/tv_episode_overview"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/flickora_padding_small"
        android:ellipsize="end"
        android:lineSpacingExtra="2dp"
        android:maxLines="3"
        android:textColor="@color/light_gray"
        android:textSize="13sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/cv_episode_still"
        tools:text="A chemistry teacher learns he has cancer and begins making difficult choices." />

</androidx.constraintlayout.widget.ConstraintLayout>


<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.textfield.TextInputLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/til_season"
    style="@style/Theme.Flickora.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="@dimen/flickora_padding_large">

    <com.google.android.material.textfield.MaterialAutoCompleteTextView
        android:id="@+id/actv_season"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:inputType="none"
        android:popupBackground="@color/dark_black"
        android:textColor="@color/white"
        android:textColorHint="@color/gray"
        app:dropDownBackgroundTint="@color/dark_black"
        tools:text="Season 1" />

</com.google.android.material.textfield.TextInputLayout>

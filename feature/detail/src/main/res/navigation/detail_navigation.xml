<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/detail_navigation"
    app:startDestination="@id/detail_fragment">

    <fragment
        android:id="@+id/detail_fragment"
        android:name="com.ilyeong.flickora.feature.detail.movie.MovieDetailFragment"
        android:label="@string/detail">

        <deepLink app:uri="android-app://com.ilyeong.flickora/detail_fragment?movieId={movieId}" />
        <deepLink app:uri="android-app://com.ilyeong.flickora/movie_detail_fragment?movieId={movieId}" />
        <argument
            android:name="movieId"
            app:argType="integer" />
        <action
            android:id="@+id/action_detail_fragment_to_detail_fragment"
            app:destination="@id/detail_fragment" />
    </fragment>

    <fragment
        android:id="@+id/tv_detail_fragment"
        android:name="com.ilyeong.flickora.feature.detail.tvdetail.TvDetailFragment"
        android:label="@string/detail">

        <deepLink app:uri="android-app://com.ilyeong.flickora/detail_fragment?tvSeriesId={tvSeriesId}" />
        <argument
            android:name="tvSeriesId"
            app:argType="integer" />
    </fragment>
</navigation>
